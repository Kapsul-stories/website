<section class="player-section">
  <div class="player-container">
    <div class="player-intro">
      <h2 class="player-title">Les <span class="marker-underline">capsules</span> du mois</h2>
      <p class="player-subtitle">Une histoire courte, ancrée dans un lieu précis. On l'écoute sur place, quand on est à moins de 50 mètres.</p>
    </div>

    <div class="player-card" data-controller="player">
      <div class="player-card-header">
        <span class="player-badge">📍 Grenoble · Museum d'Histoire Naturelle</span>
        <span class="player-category">🌿 Nature</span>
      </div>

      <div class="player-card-body">
        <div class="player-info">
          <h3 class="player-capsule-title">Un éléphant plus vrai que nature</h3>
          <span class="player-duration">2 min 34</span>
        </div>

        <div class="player-controls">
          <button class="player-btn" data-action="click->player#toggle" data-player-target="btn" aria-label="Lecture">
            <svg class="player-icon player-icon--play" data-player-target="playIcon" viewBox="0 0 24 24" fill="currentColor">
              <path d="M8 5v14l11-7z"/>
            </svg>
            <svg class="player-icon player-icon--pause" data-player-target="pauseIcon" viewBox="0 0 24 24" fill="currentColor" style="display:none">
              <path d="M6 19h4V5H6v14zm8-14v14h4V5h-4z"/>
            </svg>
          </button>

          <div class="player-waveform" data-player-target="waveform">
            <% 32.times do |i| %>
              <div class="player-bar" data-player-target="bar" style="--bar-height: <%= [30, 50, 70, 90, 75, 55, 40, 85, 65, 45, 80, 60, 95, 70, 50, 35, 88, 62, 48, 77, 55, 42, 82, 68, 52, 38, 72, 90, 60, 44, 78, 55][i] %>%"></div>
            <% end %>
          </div>

          <span class="player-time" data-player-target="time">0:00</span>
        </div>
      </div>

      <div class="player-card-footer">
        <span class="player-lock">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          Débloquée à moins de 50m du lieu
        </span>
        <span class="player-author">par Marie T.</span>
      </div>
    </div>
  </div>
</section>
